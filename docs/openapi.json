    "/health": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Liveness probe",
        "description": "Return ``{\"status\": \"ok\"}`` if the process is alive.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
