# ============================================================================
# .env.example — 单一配置入口（对齐 AGENTS.md §7）
#
# 使用方式：
#   cp .env.example .env
#   # 然后按本机实际情况修改
#
# 本文件按 *Docker compose* 形态填默认值（hostname = service 名）。
# 本机直跑（uvicorn / python main.py）请把每个 hostname 改成 `localhost` 或
# 改用 SQLite —— 每个相关行都给了 "LOCAL:" 注释。
#
# 所有配置由 `settings.py`（pydantic-settings）读取。
# 其它模块禁止直接读 os.environ。
# ============================================================================

# ── app ───────────────────────────────────────────────
APP_ENV=dev                    # dev | prod
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
# HTTP surface (serve subcommand). CSV list allowed for CORS.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173
# Allowlist of `X-Client-Id` values accepted on /v1/* (non-browser surface).
# CSV. See docs/backend/MULTI_CLIENT_AUTH_DESIGN.md.
APP_ALLOWED_CLIENT_IDS=lhx-rag-cli,lhx-rag-web

# ── auth ──────────────────────────────────────────────
# 生产环境必须显式设置非默认值，否则 Settings() 会 raise。
# 推荐用 `openssl rand -hex 32` 生成。
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAY=7
# bcrypt cost factor (rounds = 2**N); 12 ≈ 250ms on a laptop.
AUTH_BCRYPT_ROUNDS=12
# Flip to `false` to disable mass-revocation on refresh-token reuse.
AUTH_REFRESH_REUSE_DETECTION=true

# ── auth cookies (P-AUTH-2 — browser surface only) ────
# These configure the HttpOnly cookies issued on the legacy `/` surface
# when a browser opts in via `?cookie=true`. The CLI / `/v1/*` clients
# continue to use Bearer auth and are unaffected.
#
# Cookie names — only change if they collide with another app on the
# same domain. The Web BFF (`websites/`) hardcodes the same names.
# AUTH_COOKIE_ACCESS_NAME=rag_at
# AUTH_COOKIE_REFRESH_NAME=rag_rt
# Empty = same-origin only. Set when the API and web are on different
# sub-domains (e.g. `api.example.com` + `app.example.com` → `.example.com`).
# AUTH_COOKIE_DOMAIN=
# REQUIRED in production: forces cookies onto HTTPS only. Dev defaults
# to `false` so localhost (HTTP) works without a tunnel.
AUTH_COOKIE_SECURE=false
# `lax` is the right default. The refresh cookie is always written with
# `Strict` regardless (see api/cookies.py) — this only tunes the access
# cookie. Use `none` only if you need cross-site embeds AND have HTTPS.
# AUTH_COOKIE_SAMESITE=lax

# Fernet key for at-rest encryption of per-user LLM provider API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production; dev falls back to a hard-coded key with a warning.
PROVIDER_ENCRYPTION_KEY=

# ── db ────────────────────────────────────────────────
# Docker compose 形态（默认）。
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/ragdb
# LOCAL (Docker compose 起的 PG，Python 在容器外):
#   DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/ragdb
# LOCAL (零依赖 SQLite，适合调通 API、跑测试，不适合 RAG 相似度搜索):
#   DATABASE_URL=sqlite+aiosqlite:///./.dev.db
# Pool tuning (optional; defaults in settings.py).
# DB_POOL_SIZE=10
# DB_POOL_RECYCLE=1800
# DB_ECHO_SQL=false

# ── redis ─────────────────────────────────────────────
# Off by default — backend boots without a daemon. Flip on for caching + LLM rate-limit.
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
# LOCAL: REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_DEFAULT_TTL=300
# REDIS_LLM_RATE_PER_USER=30
# REDIS_LLM_RATE_WINDOW_S=60

# ── ollama ────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
# LOCAL: OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3-coder-next:cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
# Native Ollama thinking control: true/false/low/medium/high. Empty = provider/model default.
OLLAMA_THINK=true
# Bearer token for hosted/proxied ollama (e.g. ollama.com cloud).
# Leave unset for local `ollama serve`. Can also be set at runtime via
# the `/ollama-auth` slash command (this-process-only, not persisted).
# OLLAMA_API_KEY=sk-...

# ── retrieval ─────────────────────────────────────────
RAG_ENABLED=true
RAG_TOP_K=4
RAG_MIN_SCORE=0.25
# Embedding vector dim — must match the pgvector column Vector(dim).
# Default 768 corresponds to `nomic-embed-text`.
RAG_EMBED_DIM=768
# Image captioning for uploaded assets. Requires the project vision model.
RAG_IMAGE_CAPTION_ENABLED=true
RAG_IMAGE_CAPTION_MODEL=qwen3-vl:235b-cloud

# ── evaluation ────────────────────────────────────────
# Resident answer-quality judge model. Defaults to Ollama/Ollama Cloud config.
EVALUATION_ENABLED=true
EVALUATION_MODEL=gemma4:31b-cloud
EVALUATION_TIMEOUT=120

# ── rate limit ────────────────────────────────────────
RATE_LIMIT_PER_MIN=60

# ── chat / ReAct context window ───────────────────────
# Input-token ceiling per LLM call. The orchestrator compacts tool
# payloads, summarizes old turns, and trims head-first to stay under
# this. Default is sized for 128k-token models (GPT-4o, Sonnet,
# Qwen 2.5 long-context); shrink for smaller backends. Set to 0 to
# disable context management entirely (legacy behaviour).
CHAT_CONTEXT_MAX_TOKENS=96000
# Tokens reserved for the assistant reply. The 96k input + 16k reply
# split keeps headroom for chat-template framing.
CHAT_CONTEXT_RESERVE_FOR_REPLY=16000
# Trailing messages preserved verbatim by HistorySummarizer when
# pre-history overflows. Higher = more recent context kept literal.
CHAT_KEEP_RECENT_TURNS=8

# ── object storage ────────────────────────────────────
# local: store uploaded files under STORAGE_LOCAL_ROOT and serve via STORAGE_PUBLIC_BASE_URL.
# s3: use S3-compatible storage such as MinIO. No S3 defaults are hardcoded in settings.py.
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=/uploads
# For docker-compose MinIO with the API running on the host, switch STORAGE_BACKEND=s3 and uncomment:
# S3_ENDPOINT_URL=http://localhost:9000
# S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
# If the API also runs inside the compose network, use S3_ENDPOINT_URL=http://minio:9000 instead.
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=rag-assets
# S3_REGION=us-east-1
