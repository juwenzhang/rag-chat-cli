# ============================================================================
# .env.example — 单一配置入口（对齐 AGENTS.md §7）
#
# 使用方式：
#   cp .env.example .env
#   # 然后按本机实际情况修改
#
# 本文件按 *Docker compose* 形态填默认值（hostname = service 名）。
# 本机直跑（uvicorn / python main.py）请把每个 hostname 改成 `localhost` 或
# 改用 SQLite —— 每个相关行都给了 "LOCAL:" 注释。
#
# 所有配置由 `settings.py`（pydantic-settings）读取。
# 其它模块禁止直接读 os.environ。
# ============================================================================

# ── app ───────────────────────────────────────────────
APP_ENV=dev                    # dev | prod
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
# HTTP surface (serve subcommand). CSV list allowed for CORS.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173

# ── auth ──────────────────────────────────────────────
# 生产环境必须显式设置非默认值，否则 Settings() 会 raise。
# 推荐用 `openssl rand -hex 32` 生成。
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAY=7
# bcrypt cost factor (rounds = 2**N); 12 ≈ 250ms on a laptop.
AUTH_BCRYPT_ROUNDS=12
# Flip to `false` to disable mass-revocation on refresh-token reuse.
AUTH_REFRESH_REUSE_DETECTION=true

# ── db ────────────────────────────────────────────────
# Docker compose 形态（默认）。
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/ragdb
# LOCAL (Docker compose 起的 PG，Python 在容器外):
#   DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/ragdb
# LOCAL (零依赖 SQLite，适合调通 API、跑测试，不适合 RAG 相似度搜索):
#   DATABASE_URL=sqlite+aiosqlite:///./.dev.db
# Pool tuning (optional; defaults in settings.py).
# DB_POOL_SIZE=10
# DB_POOL_RECYCLE=1800
# DB_ECHO_SQL=false

# ── redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# LOCAL: REDIS_URL=redis://localhost:6379/0

# ── ollama ────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
# LOCAL: OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
# Bearer token for hosted/proxied ollama (e.g. ollama.com cloud).
# Leave unset for local `ollama serve`. Can also be set at runtime via
# the `/ollama-auth` slash command (this-process-only, not persisted).
# OLLAMA_API_KEY=sk-...

# ── retrieval ─────────────────────────────────────────
RAG_ENABLED=true
RAG_TOP_K=4
RAG_MIN_SCORE=0.25
# Embedding vector dim — must match the pgvector column Vector(dim).
# Default 768 corresponds to `nomic-embed-text`.
RAG_EMBED_DIM=768

# ── rate limit ────────────────────────────────────────
RATE_LIMIT_PER_MIN=60
