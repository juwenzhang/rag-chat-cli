{
  "base_model": "qwen/qwen2.5-0.5b",
  "output_dir": "./output/lora_model",
  "data_path": "./data/train.json",
  "num_train_epochs": 3,
  "per_device_train_batch_size": 2,
  "gradient_accumulation_steps": 4,
  "learning_rate": 3e-4,
  "lora_rank": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "target_modules": "q_proj,v_proj,k_proj,o_proj,gate_proj,up_proj,down_proj",
  "warmup_ratio": 0.03,
  "weight_decay": 0.001,
  "logging_steps": 10,
  "save_steps": 100,
  "eval_steps": 100,
  "max_grad_norm": 1.0,
  "seed": 42,
  "bf16": false,
  "fp16": true,
  "use_4bit": false
}