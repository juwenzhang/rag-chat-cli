# ─── Python bytecode / builds ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
wheels/
*.whl

# ─── Virtualenvs / uv ────────────────────────────────────
.venv/
venv/
env/
# uv itself is committed (see uv.lock, .python-version).
# Only local caches / ephemerals are ignored.

# ─── Test / lint / type caches (generated, never committed) ──
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.nox/
.hypothesis/

# ─── Coverage (pytest-cov outputs; see scripts/check_coverage.py) ──
.coverage
.coverage.*
coverage.xml
htmlcov/

# ─── AI agent runtime dirs ───────────────────────────────
# NOTE: .codebuddy/ is intentionally TRACKED (holds opsx/ slash-commands + skills).
.claude/
.codex/
.trae/
.codebuddy/

# ─── IDE / editor ────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────
.DS_Store
._*
.AppleDouble
Thumbs.db

# ─── Env / secrets ───────────────────────────────────────
# `.env.example` is tracked as the template; everything else local-only.
.env
.env.*
!.env.example

# ─── Logs / tmp ──────────────────────────────────────────
*.log
*.log.*
logs/
tmp/
.tmp/
*.bak

# ─── Node / Frontend (web-app/ lands in P8) ──────────────
node_modules/
.vite/
# Node-side coverage report directory (distinct from Python's coverage.xml).
web-app/coverage/
# unplugin auto-generated type declarations (regenerated on every dev start).
auto-imports.d.ts
components.d.ts
# msw service worker (created per-dev via `pnpm dlx msw init`).
web-app/public/mockServiceWorker.js

# ─── Project-specific runtime artefacts ──────────────────
# Model / inference outputs.
outputs/
# Conversation replay files written by the CLI at runtime (not source data).
conversations/*.json
# Auto-crawled knowledge snapshots (if/when knowledge/ is re-introduced).
knowledge/articles/frontend/chat_*.json
knowledge/articles/frontend/chat_*.md

# local sqlite db (if used instead of Postgres in dev); not relevant to production.
.dev.db
