{
  "name": "rag-chat-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,less,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,less,json,md}\"",
    "stylelint": "stylelint \"src/**/*.{less,vue}\"",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "element-plus": "^2.8.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@types/node": "^22.0.0",
    "@unocss/preset-attributify": "^0.63.0",
    "@unocss/preset-icons": "^0.63.0",
    "@unocss/preset-uno": "^0.63.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.0",
    "less": "^4.2.0",
    "msw": "^2.4.0",
    "prettier": "^3.3.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-less": "^3.0.1",
    "typescript": "^5.6.0",
    "unocss": "^0.63.0",
    "unplugin-auto-import": "^0.18.0",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.4.0",
    "vite-plugin-vue-devtools": "^7.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}