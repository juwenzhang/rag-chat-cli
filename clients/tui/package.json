{
  "name": "@luhanxin/rag-tui",
  "version": "0.1.1",
  "description": "lhx-rag — Ink-based terminal client for the rag-ai-cli FastAPI backend.",
  "type": "module",
  "bin": {
    "lhx-rag": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "rslib build",
    "dev": "rslib build --watch",
    "start": "tsx src/index.tsx",
    "start:dist": "node dist/index.mjs"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "fastest-levenshtein": "^1.0.16",
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.1.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@rslib/core": "^0.5.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "lint-staged": "^15.2.10",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0"
  }
}
